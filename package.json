{
  "name": "oneplace",
  "private": true,
  "version": "0.1.14",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "build": "tauri build",
    "build:web": "tsc -b && vite build --base ./",
    "build:installer": "tauri build",
    "build:release": "node scripts/build-signed-release.mjs",
    "dist": "tauri build",
    "release:publish": "node scripts/publish-updater-release.mjs",
    "lint": "eslint .",
    "test": "npm run test:css && npm run test:hierarchy && npm run test:folder-import && npm run test:open-notebook && npm run test:package && npm run test:shortcuts && npm run test:references && npm run test:markmap && npm run test:security",
    "test:css": "node --test --experimental-strip-types scripts/cssStructure.test.ts",
    "test:hierarchy": "node --import tsx --test scripts/appModelHierarchy.test.ts",
    "test:folder-import": "node --import tsx --test scripts/folderTreeImport.test.ts",
    "test:open-notebook": "node --import tsx --test scripts/openNotebookRecovery.test.ts",
    "test:package": "node --import tsx --test scripts/onePlacePackage.test.ts",
    "test:shortcuts": "node --import tsx --test scripts/oneNoteShortcuts.test.ts",
    "test:references": "node --test --experimental-strip-types scripts/referenceManager.test.ts",
    "test:markmap": "node --test --experimental-strip-types scripts/markmapFeature.test.ts",
    "test:security": "node --import tsx --test scripts/appModelSecurity.test.ts scripts/desktopStorage.test.ts scripts/secretHash.test.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/hanken-grotesk": "^5.2.8",
    "@fontsource/spline-sans-mono": "^5.2.8",
    "@radix-ui/react-context-menu": "^2.3.1",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-toggle-group": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "dompurify": "^3.4.11",
    "lucide-react": "^1.21.0",
    "markmap-common": "^0.18.9",
    "markmap-lib": "^0.18.12",
    "markmap-view": "^0.18.12",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  },
  "overrides": {
    "vite": {
      "esbuild": "0.28.1"
    }
  }
}
